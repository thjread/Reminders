{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowJs": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "sourceMap": true
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["src/sugar.js", "src/sw.js"]
}
